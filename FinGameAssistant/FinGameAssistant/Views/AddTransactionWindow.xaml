<Window x:Class="FinGameAssistant.Views.AddTransactionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinGameAssistant.ViewModels"
        mc:Ignorable="d"
        Title="Добавление операции" 
        Height="500" Width="450"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="FormFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="IsTodayHighlighted" Value="True"/>
            <Setter Property="IsDropDownOpen" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox Grid.Column="0" 
                                               FontSize="{TemplateBinding FontSize}"
                                               Padding="5"
                                               BorderThickness="0"
                                               IsReadOnly="True"
                                               IsHitTestVisible="False"
                                               Text="{Binding SelectedDate, StringFormat='dd.MM.yyyy', RelativeSource={RelativeSource TemplatedParent}}"/>

                                <Button Grid.Column="1" 
                                    x:Name="PART_Button"
                                    Content="📅" 
                                    Width="30"
                                    Height="30"
                                    FontSize="16"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Margin="0,0,5,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TypeToggleStyle" TargetType="RadioButton">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#3498DB"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Новая операция" 
                   FontSize="22" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <TextBlock Text="Тип операции" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="#34495E"
                           Margin="0,0,0,5"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <RadioButton Grid.Column="0" 
                                 Content="Доход" 
                                 Style="{StaticResource TypeToggleStyle}"
                                 GroupName="TransactionType"
                                 IsChecked="{Binding IsIncome, Mode=TwoWay}"/>

                    <RadioButton Grid.Column="2" 
                                 Content="Расход" 
                                 Style="{StaticResource TypeToggleStyle}"
                                 GroupName="TransactionType"
                                 IsChecked="{Binding IsExpense, Mode=TwoWay}"/>
                </Grid>

                <TextBlock Text="Сумма" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="#34495E"
                           Margin="0,0,0,5"/>

                <TextBox x:Name="AmountTextBox"
                         Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormFieldStyle}"
                         PreviewTextInput="AmountTextBox_PreviewTextInput"
                         GotFocus="AmountTextBox_GotFocus"
                         LostFocus="AmountTextBox_LostFocus"/>

                <TextBlock Text="Категория" 
                   FontSize="14" 
                   FontWeight="SemiBold" 
                   Foreground="#34495E"
                   Margin="0,0,0,5"/>

                <ComboBox ItemsSource="{Binding Categories}"
                  SelectedItem="{Binding SelectedCategory}"
                  Style="{StaticResource FormComboBoxStyle}"
                  IsEditable="True"
                  Text="{Binding NewCategory, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Дата" 
           FontSize="14" 
           FontWeight="SemiBold" 
           Foreground="#34495E"
           Margin="0,0,0,5"/>

                <DatePicker SelectedDate="{Binding TransactionDate}"
            Height="40"
            FontSize="14"
            BorderBrush="#DDDDDD"
            BorderThickness="1"
            Background="White"
            Margin="0,5,0,15"
            IsTodayHighlighted="True"
            FirstDayOfWeek="Monday">
                    <DatePicker.Resources>
                        <Style TargetType="DatePickerTextBox">
                            <Setter Property="IsReadOnly" Value="True"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Foreground" Value="Black"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DatePicker.Resources>
                </DatePicker>

                <TextBlock Text="Описание (необязательно)" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="#34495E"
                           Margin="0,0,0,5"/>

                <TextBox Text="{Binding Description}"
                         Style="{StaticResource FormFieldStyle}"
                         Height="80"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Content="Отмена" 
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#E0E0E0"
                    Foreground="#2C3E50"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="2" 
                    Content="{Binding ButtonText}" 
                    Style="{StaticResource ActionButtonStyle}"
                    Background="{Binding ButtonColor}"
                    Foreground="White"
                    Click="SaveButton_Click"
                    IsEnabled="{Binding CanSave}"/>
        </Grid>
    </Grid>
</Window>