<Window x:Class="FinGameAssistant.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:FinGameAssistant.Converters"
        Title="FinGame Assistant - Вход" 
        Height="744" Width="380"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <converters:BooleanToTabBackgroundConverter x:Key="BooleanToTabBackgroundConverter"/>
        <converters:BooleanToTabForegroundConverter x:Key="BooleanToTabForegroundConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="10" Opacity="0.05" ShadowDepth="2"/>

        <Style x:Key="FormFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="FormPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3498DB"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Image Source="/Images/icon.ico" Width="48" Height="48" Margin="0,0,10,0"/>
            <StackPanel>
                <TextBlock Text="FinGame Assistant" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Управляй финансами играючи" FontSize="12" Foreground="#7F8C8D"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="10" 
                Padding="20"
                Effect="{StaticResource ShadowEffect}">
            <StackPanel>

                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" 
                            Content="Вход" 
                            Background="{Binding IsLoginMode, Converter={StaticResource BooleanToTabBackgroundConverter}}"
                            Foreground="{Binding IsLoginMode, Converter={StaticResource BooleanToTabForegroundConverter}}"
                            BorderThickness="0"
                            Height="35"
                            Click="LoginTab_Click"/>

                    <Button Grid.Column="1" 
                            Content="Регистрация" 
                            Background="{Binding IsRegisterMode, Converter={StaticResource BooleanToTabBackgroundConverter}}"
                            Foreground="{Binding IsRegisterMode, Converter={StaticResource BooleanToTabForegroundConverter}}"
                            BorderThickness="0"
                            Height="35"
                            Click="RegisterTab_Click"/>
                </Grid>

                <StackPanel>
                    <TextBlock Text="Имя пользователя" 
                               FontSize="12" 
                               Foreground="#34495E"
                               Margin="0,0,0,5"/>
                    <TextBox x:Name="UsernameTextBox"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormFieldStyle}"/>

                    <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Email" 
                                   FontSize="12" 
                                   Foreground="#34495E"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="EmailTextBox"
                                 Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FormFieldStyle}"/>
                    </StackPanel>

                    <TextBlock Text="Пароль" 
                               FontSize="12" 
                               Foreground="#34495E"
                               Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource FormPasswordStyle}"/>

                    <StackPanel Visibility="{Binding IsRegisterMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Text="Подтверждение пароля" 
                                   FontSize="12" 
                                   Foreground="#34495E"
                                   Margin="0,0,0,5"/>
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource FormPasswordStyle}"/>
                    </StackPanel>

                    <Button Content="{Binding ActionButtonText}" 
                            Style="{StaticResource ActionButtonStyle}"
                            Background="{Binding ActionButtonColor}"
                            Foreground="White"
                            Margin="0,10,0,0"
                            Click="ActionButton_Click"/>

                    <Button Content="Продолжить как гость" 
                            Style="{StaticResource LinkButtonStyle}"
                            Margin="0,10,0,0"
                            Click="GuestButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3" 
                   Text="© 2026 FinGame Assistant" 
                   FontSize="11" 
                   Foreground="#95A5A6"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"/>
    </Grid>
</Window>