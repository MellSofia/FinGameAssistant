<Window x:Class="FinGameAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:FinGameAssistant.ViewModels"
        xmlns:converters="clr-namespace:FinGameAssistant.Converters"
        xmlns:views="clr-namespace:FinGameAssistant.Views"
        Title="FinGame Assistant" 
        Height="700"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Window.Resources>
        <converters:TypeToColorConverter x:Key="TypeToColorConverter"/>
        <DropShadowEffect x:Key="ShadowEffect" BlurRadius="15" Opacity="0.1" ShadowDepth="2"/>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="Transparent" BorderThickness="0" Padding="20,10">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" 
                                            VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="White"/>
                                <Setter Property="Foreground" Value="#3498DB"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EEEEEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="20" Effect="{StaticResource ShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Image Source="/Images/icon.ico" Width="37" Height="35" Margin="0,0,10,0"/>
                    <TextBlock Text="FinGame Assistant" FontSize="20" FontWeight="Bold" Foreground="#2C3E50"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#F0F8FF" CornerRadius="20" Padding="15,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="16" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding CurrentUser.Username}" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F0F8FF" CornerRadius="20" Padding="15,5" Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⭐" FontSize="16" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding CurrentUser.Level, StringFormat='Уровень {0}'}" 
                                       FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F0F8FF" CornerRadius="20" Padding="15,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✨" FontSize="16" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding CurrentUser.Experience, StringFormat='Опыт: {0}'}" 
                                       FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="2" Background="#3498DB" CornerRadius="20" Padding="20,5">
                    <TextBlock Text="{Binding CurrentUser.TotalBalance, StringFormat='Баланс: {0:N0} ₽'}" 
                               FontWeight="Bold" Foreground="White"/>
                </Border>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedTabIndex}" Margin="20">
            <TabItem Header="🏠 Главная">
                <views:DashboardView/>
            </TabItem>
            <TabItem Header="📊 Транзакции">
                <views:TransactionsView DataContext="{Binding TransactionsViewModel}"/>
            </TabItem>
            <TabItem Header="🎯 Цели">
                <views:GoalsView DataContext="{Binding GoalsViewModel}"/>
            </TabItem>
            <TabItem Header="🏆 Достижения">
                <views:AchievementsView DataContext="{Binding AchievementsViewModel}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>