<Window x:Class="FinGameAssistant.Views.ContributeToGoalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Пополнить цель" 
        Height="358" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="FormFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="{Binding GoalName}" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   Margin="0,0,0,15"/>

        <Border Grid.Row="1" 
                Background="#F0F8FF" 
                CornerRadius="5" 
                Padding="10"
                Margin="0,0,0,15">
            <TextBlock Text="{Binding UserBalanceInfo}" 
                       Foreground="#2C3E50"
                       FontWeight="SemiBold"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Текущий прогресс" 
                           FontSize="11" 
                           Foreground="#7F8C8D"/>
                <TextBlock Text="{Binding CurrentProgress}" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#2C3E50"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Осталось накопить" 
                           FontSize="11" 
                           Foreground="#7F8C8D"/>
                <TextBlock Text="{Binding RemainingAmount, StringFormat='{}{0:N0} ₽'}" 
                           FontSize="13" 
                           FontWeight="SemiBold" 
                           Foreground="#E74C3C"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3">
            <TextBlock Text="Сумма пополнения" 
                       FontSize="14" 
                       FontWeight="SemiBold" 
                       Foreground="#34495E"
                       Margin="0,0,0,5"/>

            <TextBox x:Name="AmountTextBox"
                     Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FormFieldStyle}"
                     PreviewTextInput="NumberTextBox_PreviewTextInput" Height="47"/>
        </StackPanel>

        <Grid Grid.Row="4" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Content="Отмена" 
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#E0E0E0"
                    Foreground="#2C3E50"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="2" 
                    Content="Пополнить" 
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#27AE60"
                    Foreground="White"
                    Click="ContributeButton_Click"
                    IsEnabled="{Binding CanContribute}"/>
        </Grid>
    </Grid>
</Window>