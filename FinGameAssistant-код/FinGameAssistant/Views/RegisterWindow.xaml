<Window x:Class="FinGameAssistant.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:FinGameAssistant.Converters"
        mc:Ignorable="d"
        Title="Регистрация аккаунта" 
        Height="580" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="#F5F7FA">

    <Window.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <Style x:Key="FormFieldStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="FormPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Создание аккаунта" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Заполните данные для регистрации" 
                       FontSize="12" 
                       Foreground="#7F8C8D"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Имя пользователя *" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="UsernameTextBox"
                            Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource FormFieldStyle}"/>
                <TextBlock Text="{Binding UsernameError}"
                           Foreground="#E74C3C"
                           FontSize="10"
                           Margin="0,-10,0,5"
                           Visibility="{Binding UsernameError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <TextBlock Text="Email *" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="EmailTextBox"
                            Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                            Style="{StaticResource FormFieldStyle}"/>          
                <TextBlock Text="{Binding EmailError}"
                           Foreground="#E74C3C"
                           FontSize="10"
                           Margin="0,-10,0,5"
                           Visibility="{Binding EmailError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <TextBlock Text="Пароль *" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="PasswordBox"
                             Style="{StaticResource FormPasswordStyle}"/>
                <TextBlock Text="{Binding PasswordError}"
                           Foreground="#E74C3C"
                           FontSize="10"
                           Margin="0,-10,0,5"
                           Visibility="{Binding PasswordError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <TextBlock Text="Подтверждение пароля *" 
                           FontSize="12" 
                           FontWeight="SemiBold"
                           Foreground="#34495E"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="ConfirmPasswordBox"
                             Style="{StaticResource FormPasswordStyle}"/>
                <TextBlock Text="{Binding ConfirmPasswordError}"
                           Foreground="#E74C3C"
                           FontSize="10"
                           Margin="0,-10,0,5"
                           Visibility="{Binding ConfirmPasswordError, Converter={StaticResource StringToVisibilityConverter}}"/>

                <CheckBox IsChecked="{Binding AgreeToTerms}"
                          Margin="0,10,0,15">
                    <TextBlock TextWrapping="Wrap">
                        Я согласен с условиями использования
                    </TextBlock>
                </CheckBox>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" 
                    Content="Отмена" 
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#E0E0E0"
                    Foreground="#2C3E50"
                    Click="CancelButton_Click"/>

            <Button Grid.Column="2" 
                    Content="Зарегистрироваться" 
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#27AE60"
                    Foreground="White"
                    Command="{Binding RegisterCommand}"  
                IsEnabled="{Binding CanRegister}"/>
        </Grid>
    </Grid>
</Window>