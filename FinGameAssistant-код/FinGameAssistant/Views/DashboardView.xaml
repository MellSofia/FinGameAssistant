<UserControl x:Class="FinGameAssistant.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:FinGameAssistant.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#F5F7FA">

    <UserControl.Resources>
        <DropShadowEffect x:Key="ShadowEffect" 
                          BlurRadius="15" 
                          Opacity="0.1" 
                          ShadowDepth="2"/>

        <local:TypeToColorConverter x:Key="TypeToColorConverter"/>

        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2980B9"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="{Binding CurrentUser.Username, StringFormat='Привет, {0}!'}" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
                <StackPanel>
                    <Border Background="White" 
                            CornerRadius="10" 
                            Padding="20" 
                            Margin="0,0,0,20"
                            Effect="{StaticResource ShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="Текущий баланс" 
                                       FontSize="14" 
                                       Foreground="#7F8C8D"/>
                            <TextBlock Text="{Binding CurrentUser.TotalBalance, StringFormat='{}{0:N2} ₽'}" 
                                       FontSize="36" 
                                       FontWeight="Bold" 
                                       Foreground="#2C3E50"/>
                        </StackPanel>
                    </Border>

                    <Border Background="White" 
                            CornerRadius="10" 
                            Padding="20" 
                            Margin="0,0,0,20"
                            Effect="{StaticResource ShadowEffect}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Доходы" 
                                           FontSize="14" 
                                           Foreground="#27AE60"/>
                                <TextBlock Text="{Binding MonthlyIncome, StringFormat='+{0:N2} ₽'}" 
                                           FontSize="20" 
                                           FontWeight="Bold" 
                                           Foreground="#27AE60"/>
                                <TextBlock Text="за текущий месяц" 
                                           FontSize="11" 
                                           Foreground="#95A5A6"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Расходы" 
                                           FontSize="14" 
                                           Foreground="#E74C3C"/>
                                <TextBlock Text="{Binding MonthlyExpense, StringFormat='-{0:N2} ₽'}" 
                                           FontSize="20" 
                                           FontWeight="Bold" 
                                           Foreground="#E74C3C"/>
                                <TextBlock Text="за текущий месяц" 
                                           FontSize="11" 
                                           Foreground="#95A5A6"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="White" 
                            CornerRadius="10" 
                            Padding="20"
                            Effect="{StaticResource ShadowEffect}">
                        <StackPanel>
                            <TextBlock Text="Активные цели" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       Foreground="#2C3E50"
                                       Margin="0,0,0,15"/>

                            <ItemsControl ItemsSource="{Binding ActiveGoals}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F8F9FA" 
                                                CornerRadius="5" 
                                                Padding="10"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" 
                                                               Text="{Binding Name}" 
                                                               FontWeight="Bold"
                                                               Foreground="#2C3E50"/>

                                                    <TextBlock Grid.Column="1" 
                                                               Text="{Binding ProgressPercentage, StringFormat='{}{0}%'}" 
                                                               Foreground="#3498DB"/>
                                                </Grid>

                                                <ProgressBar Grid.Row="1" 
                                                             Value="{Binding ProgressPercentage}" 
                                                             Height="5"
                                                             Foreground="#3498DB"
                                                             Background="#E0E0E0"
                                                             Margin="0,5,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="20"
                        Effect="{StaticResource ShadowEffect}">
                    <StackPanel>
                        <TextBlock Text="Последние операции" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="#2C3E50"
                                   Margin="0,0,0,15"/>

                        <ItemsControl ItemsSource="{Binding RecentTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEEEEE" 
                                            BorderThickness="0,0,0,1" 
                                            Padding="5"
                                            Margin="0,0,0,5">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding Date, StringFormat='dd.MM'}" 
                                                       Foreground="#95A5A6"
                                                       Width="40"/>

                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Category}" 
                                                       Foreground="#2C3E50"
                                                       Margin="10,0"/>

                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding Amount, StringFormat='{}{0:N0} ₽'}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="+ Добавить операцию" 
                            Command="{Binding OpenAddTransactionCommand}"
                            Style="{StaticResource RoundedButtonStyle}"
                            Margin="0,15,0,0"/>
                    </StackPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>